# anchor-hub local development environment variables
# Copy to .env for local development: cp .env.example .env

# --- Service Mode ---
# When true, all services use in-memory stubs (skip JWT validation, etc.)
AUTH_BYPASS=true

# Override individual services to use real implementations
USE_REAL_AUTH=false
USE_REAL_CLIENT_REGISTRY=false
USE_REAL_USER_REGISTRY=false
USE_REAL_AUDIT_LOGGER=false

# --- Policy ---
AUTHZ_ENFORCE_SCOPES=false
POLICY_STUB_MODE=allow-all

# --- Local Server ---
PORT=3000

# --- AWS (production only — not needed for local dev with stubs) ---
# AWS_REGION=us-east-1
# DYNAMODB_TABLE_CLIENTS=anchor-hub-clients
# DYNAMODB_TABLE_USERS=anchor-hub-users
# DYNAMODB_TABLE_AUDIT=anchor-hub-audit

# --- Clerk (production only — not needed when AUTH_BYPASS=true) ---
# CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json
# CLERK_ISSUER=https://your-clerk-instance.clerk.accounts.dev

# --- Dev Identity Defaults (used by AuthStub when no headers provided) ---
# DEV_USER_ID=usr_00000000-0000-0000-0000-000000000001
# DEV_CLIENT_ID=cli_00000000-0000-0000-0000-000000000001
# DEV_CLIENT_TYPE=first-party
# DEV_AUTH_SCOPES=anchor-log.entries.read anchor-log.entries.write anchor-hub.admin
